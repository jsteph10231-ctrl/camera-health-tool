    "key": "MAC Address",
    "Offline For (hrs)": "Offline Hrs",
    "Ticket Status": "Ticket",
    "Error Flags": "Errors",
    "Create TDX": "TDX",
}

# Widths tuned from the provided browser screenshot.
CAMERA_GRID_WIDTHS_ALL = {
    "Health": 180,
    "Device Name Base": 275,
    "key": 135,
    "IP Address": 130,
    "Offline For (hrs)": 105,
    "Ticket ID": 105,
    "Error Flags": 360,
    "Ping Status": 120,
    "Servers": 355,
    "disposition": 160,
    "notes": 260,
    "Location": 220,
    "Ticket Status": 120,
}

CAMERA_GRID_WIDTHS_ISSUES = {
    "Health": 180,
    "Device Name Base": 275,
    "key": 135,
    "IP Address": 130,
    "Ping Status": 120,
    "Offline For (hrs)": 105,
    "Ticket ID": 105,
    "Create TDX": 70,
    "Error Flags": 360,
